rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          ('email' in request.auth.token && request.auth.token.email == "manojprajapatiworks@gmail.com")
        );
    }

    function isValidServiceRequest() {
      return request.resource.data.keys().hasAll(['name', 'phone', 'motorType', 'issue', 'date']) &&
             request.resource.data.get('name', '') is string && request.resource.data.get('name', '').size() < 100 &&
             request.resource.data.get('phone', '') is string && request.resource.data.get('phone', '').size() < 50 &&
             request.resource.data.get('motorType', '') is string && request.resource.data.get('motorType', '').size() < 100 &&
             request.resource.data.get('issue', '') is string && request.resource.data.get('issue', '').size() < 2000 &&
             request.resource.data.get('date', '') is string && request.resource.data.get('date', '').size() < 50;
    }

    function isValidUser() {
      return request.resource.data.keys().hasAll(['role', 'email']) &&
             request.resource.data.get('role', '') == 'admin' &&
             request.resource.data.get('email', '') is string && request.resource.data.get('email', '').size() < 100;
    }

    match /content/main {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /serviceRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if isValidServiceRequest();
      allow update: if isAdmin() && isValidServiceRequest();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && isValidUser();
      allow delete: if isAdmin();
    }
  }
}
